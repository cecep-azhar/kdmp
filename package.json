    "@payloadcms/ui": "^3.81.0",
    "cross-env": "^7.0.3",
    "graphql": "^16.9.0",
    "next": "^15.3.0",
    "payload": "^3.81.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0",
